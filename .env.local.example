NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Twilio — get these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
# WhatsApp: use the sandbox number or your approved WhatsApp sender
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Twilio Verify Service SID — create one at console.twilio.com/verify/services
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin access — comma-separated Supabase auth user ids (uuid).
# These users see /admin and can rename any Hotname via the admin panel.
# Find your id in Supabase → Authentication → Users.
HOTNAME_ADMIN_IDS=
